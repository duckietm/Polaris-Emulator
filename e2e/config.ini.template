db.hostname=${E2E_DB_HOST}
db.port=${E2E_DB_PORT}
db.database=${E2E_DB_NAME}
db.username=${E2E_DB_USER}
db.password=${E2E_DB_PASSWORD}
db.params=?useUnicode=true&characterEncoding=utf8
db.pool.minsize=2
db.pool.maxsize=10
db.pool.connection_timeout_ms=10000
db.pool.idle_timeout_ms=600000
db.pool.max_lifetime_ms=1800000
db.pool.validation_timeout_ms=5000
db.pool.leak_detection_ms=0

game.host=127.0.0.1
game.port=${E2E_RAW_PORT}
rcon.host=127.0.0.1
rcon.port=${E2E_RCON_PORT}
ws.enabled=true
ws.host=127.0.0.1
ws.port=${E2E_GAME_PORT}

enc.enabled=false
enc.e=3
enc.n=1
enc.d=1
crypto.ws.enabled=false
ws.whitelist=localhost,127.0.0.1,error
e2e.enabled=true
session.reconnect.grace.seconds=30
client.release.allowed=NITRO-3-6-0
habbo.console.style=plain
